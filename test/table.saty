@require: stdja
@require: itemize
@require: code
@require: math
@require: tabular

let-inline ctx \todo =
  let ctx-todo =
      ctx |> set-text-color Color.red
    in
      read-inline ctx-todo

let-inline ctx \done =
  let ctx-done =
      ctx |> set-text-color (Color.rgb 0. 1. 0.)
    in
      read-inline ctx-done

let font-ratio-cjk = 0.88
let get-quad-size ctx =
  get-font-size ctx *' font-ratio-cjk
let-block ctx +quote it =
  let qsize = get-quad-size ctx in
  let pads = (qsize, 0pt, 0pt, 0pt) in
  let decoset = VDecoSet.quote-round 6pt 4pt (Gray(0.75)) in
  block-frame-breakable ctx pads decoset
    (fun ctx -> read-block ctx it) in
document (|
  title = {};
  author = {};
  show-title = true;
  show-toc = false;
|) '<
+section ?:(`table-example`) {Table Example} <
+p {
  This document exercises pandoc table output with the SATySFi template.
}
+pn{\emph{Grocery list}}
+pn{
\tabular(fun cellf multif empty -> [
[
cellf {Item} ;
cellf {Quantity} ;
cellf {Notes} ;
];
[
cellf {Apple};
cellf {3};
cellf {left-aligned text};
];
[
cellf {Bread};
cellf {1};
cellf {right-aligned number};
];
[
cellf {Milk};
cellf {2};
cellf {mixed content};
];
          ])(fun xs ys -> (
              match (ys, List.reverse ys) with
              | (y0 :: y1 :: _, ylast :: _) ->
                  ( match (xs, List.reverse xs) with
                    | (x0 :: x1 :: _, xlast :: _) ->
                        let grlstY =
                          [y0; ylast] |> List.map (fun y ->
                            stroke 1pt Color.black (Gr.line (x0, y) (xlast, y)))
                        in
                        (stroke 0.5pt Color.black (Gr.line (x1, y0) (x1, ylast)))
                          :: (stroke 0.5pt Color.black (Gr.line (x0, y1) (xlast, y1))) :: grlstY

                    | _ -> []
                  )
              | _ -> []
          ));
  
}
>
>
